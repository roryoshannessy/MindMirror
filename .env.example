# MindMirror — copy to `.env.local` and fill. Brand strings live in `config/brand.ts`.

# Firebase client (Firebase console → Project settings → Your apps → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Typical patterns once you create a project (replace YOUR_PROJECT_ID):
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com

# Optional: local emulators (`firebase emulators:start`)
# NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Firebase Admin (server only). Full service account JSON string, or omit on Vercel and use ADC.
FIREBASE_ADMIN_CREDENTIALS=

# Site URL (canonical, Stripe return URLs later)
NEXT_PUBLIC_SITE_URL=https://getmindmirror.com

# Stripe — use test keys locally. `npm run stripe:sync` loads `.env` then `.env.local` (dotenv) and needs STRIPE_SECRET_KEY.
# Tag catalog products with metadata foundation = true; each recurring price needs lookup_key
# and metadata internal_id (catalog plan id). Optional: product metadata catalog_default_plan_id.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_API_VERSION=2026-03-25.dahlia
STRIPE_PUBLISHABLE_KEY=

# Dev only: Allow placeholder Stripe checkout (requires NODE_ENV !== "production").
# In production, placeholder prices will fail closed and return 503.
# ALLOW_PLACEHOLDER_CHECKOUT=1

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Meta
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_TEST_EVENT_CODE=

# Transactional email (magic link).
# - Dev: leave EMAIL_SENDER_PROVIDER unset (empty) — messages are logged to the server console instead of sent.
# - Production: EMAIL_SENDER_PROVIDER=http uses the Resend HTTP API (see lib/email-sender.ts); set EMAIL_SENDER_API_KEY.
EMAIL_SENDER_PROVIDER=
EMAIL_SENDER_API_KEY=
EMAIL_SENDER_SMTP_URL=
EMAIL_SENDER_FROM=

# Set to 1 to skip PostHog, Meta pixel, and attribution init (instrumentation + provider).
# NEXT_PUBLIC_ANALYTICS_DISABLED=1

# Optional: gate PostHog + Meta until the user accepts (shows a bottom banner). First-party
# attribution in localStorage still runs from instrumentation-client.
# NEXT_PUBLIC_ANALYTICS_REQUIRES_CONSENT=1

# Set to 0 to send only anonymous PostHog identify (no email trait) and skip Meta Pixel userId.
# Default (unset) matches legacy behaviour: email + uid forwarded when consent allows vendors.
# NEXT_PUBLIC_ANALYTICS_SEND_PII=0

# Rate limiting (required in production for abuse protection across serverless instances).
# Without these, rate limiting is in-process only and provides NO protection on multi-instance deploys.
# Get credentials from https://upstash.com → Create Redis database → copy REST URL and token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Lead capture abuse (optional but recommended for public POST /api/lead/capture):
# Set both to require Turnstile; verified Firebase ID tokens (e.g. after Google sign-in) bypass Turnstile.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

CRON_SECRET=
